rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isGroupMember(groupId) {
      return isSignedIn() && exists(/databases/$(database)/documents/groups/$(groupId)) && 
             request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'members', 'ownerId', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.members is list && data.members.size() > 0 && data.members.size() <= 100 &&
             data.members[0] is string && 
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidGroupUpdate(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.members is list && data.members.size() > 0 && data.members.size() <= 100 &&
             data.ownerId == existing().ownerId &&
             data.createdAt == existing().createdAt;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'color']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.color is string && data.color.size() <= 20 &&
             (data.get('avatarUrl', '') is string);
    }

    function isValidUserUpdate(data) {
      return data.id == existing().id &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.color is string && data.color.size() <= 20;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['description', 'amount', 'paidById', 'categoryId', 'date', 'splitMode', 'involvedUserIds', 'createdAt']) &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 200 &&
             data.amount is number && data.amount >= 0 &&
             data.paidById is string && data.paidById.size() <= 128 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.splitMode is string && data.splitMode.size() <= 20 &&
             data.involvedUserIds is list && data.involvedUserIds.size() > 0 && data.involvedUserIds.size() <= 100 &&
             (data.get('isSettled', false) is bool) &&
             data.createdAt == request.time;
    }

    function isValidExpenseUpdate(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() <= 200 &&
             data.amount is number && data.amount >= 0 &&
             data.paidById is string && data.paidById.size() <= 128 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.date is string && data.date.size() <= 50 &&
             data.splitMode is string && data.splitMode.size() <= 20 &&
             data.involvedUserIds is list && data.involvedUserIds.size() > 0 && data.involvedUserIds.size() <= 100 &&
             (data.get('isSettled', false) is bool) &&
             data.createdAt == existing().createdAt;
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'name', 'color', 'icon']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.color is string && data.color.size() <= 20 &&
             data.icon is string && data.icon.size() <= 50;
    }

    function isValidCategoryUpdate(data) {
      return data.id == existing().id &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.color is string && data.color.size() <= 20 &&
             data.icon is string && data.icon.size() <= 50;
    }

    match /groups/{groupId} {
      allow create: if isSignedIn() && isValidId(groupId) && isValidGroup(incoming()) && request.auth.uid in incoming().members;
      allow read: if isSignedIn() && request.auth.uid in existing().members;
      allow delete: if isSignedIn() && (
        existing().get('ownerId', '') == request.auth.uid ||
        (!existing().keys().hasAll(['ownerId']) && request.auth.uid in existing().members)
      );
      
      // Allow update if member, OR if joining by appending own UID to members array
      allow update: if isSignedIn() && (
        (request.auth.uid in existing().members && isValidGroupUpdate(incoming())) ||
        (
          !(request.auth.uid in existing().members) &&
          request.auth.uid in incoming().members &&
          incoming().diff(existing()).affectedKeys().hasOnly(['members'])
        )
      );
      
      match /users/{userId} {
        allow read: if isGroupMember(groupId);
        allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming()) && (userId == request.auth.uid || isGroupMember(groupId));
        allow update: if isSignedIn() && isValidId(userId) && (userId == request.auth.uid || isGroupMember(groupId)) && isValidUserUpdate(incoming());
        allow delete: if isSignedIn() && isValidId(userId) && (userId == request.auth.uid || isGroupMember(groupId));
      }
      
      match /categories/{categoryId} {
        allow read: if isGroupMember(groupId);
        allow create: if isSignedIn() && isValidId(categoryId) && isValidCategory(incoming()) && isGroupMember(groupId);
        allow update: if isSignedIn() && isValidId(categoryId) && isGroupMember(groupId) && isValidCategoryUpdate(incoming());
        allow delete: if isSignedIn() && isValidId(categoryId) && isGroupMember(groupId);
      }
      
      match /expenses/{expenseId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId) && isValidId(expenseId) && isValidExpense(incoming()) && (request.auth.uid in incoming().involvedUserIds || request.auth.uid == incoming().paidById);
        allow update: if isGroupMember(groupId) && isValidId(expenseId) && isValidExpenseUpdate(incoming());
        allow delete: if isGroupMember(groupId) && isValidId(expenseId) && (existing().paidById == request.auth.uid || request.auth.uid in existing().involvedUserIds);
      }
    }
  }
}
